{
  "name": "podomed-excellence-sync",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "prisma migrate deploy && tsx watch server.ts",
    "setup": "prisma migrate deploy && prisma db seed",
    "build": "cross-env NODE_ENV=production prisma generate && next build",
    "start": "prisma migrate deploy && cross-env NODE_ENV=production tsx server.ts",
    "postinstall": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "lint": "next lint"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^2.4.3",
    "cross-env": "^7.0.3",
    "date-fns": "^4.1.0",
    "jose": "^6.0.10",
    "lucide-react": "^0.488.0",
    "next": "14.2.35",
    "prisma": "^6.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tsx": "^4.19.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.14",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
