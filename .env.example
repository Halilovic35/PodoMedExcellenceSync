# Local (Docker: docker compose up -d)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/podomed?schema=public"

# Railway: in the web service → Variables → add DATABASE_URL and reference your Postgres service.

AUTH_SECRET="replace-with-a-long-random-string-min-16-chars"
NODE_ENV="development"

# Optional: one-time seeding endpoint protection (Railway)
# SEED_KEY="your-long-random-string-min-16-chars"
